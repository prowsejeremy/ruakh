DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=ruakh
DATABASE_USER=ruakh
DATABASE_PASSWORD=ruakh

DATABASE_URL=postgres://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}

# Web Push (generated with: npx web-push generate-vapid-keys)
PUBLIC_VAPID_KEY=PUBLIC_VAPID_KEY
PRIVATE_VAPID_KEY=PRIVATE_VAPID_KEY
VAPID_SUBJECT=mailto:myemail.com

# Admin pre-auth gate (optional — leave unset to disable). When set, /admin
# 404s for anyone without this token; visit /admin?token=<value> once per
# browser to unlock (grants a year-long httpOnly cookie). Use a long random
# value, e.g.: openssl rand -base64 32
# ADMIN_ACCESS_TOKEN=
